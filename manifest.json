{
  "manifest_version": 3,
  "name": "Timestamp Player for YouTube",
  "version": "0.8.0",
  "description": "The best way to enjoy albums on YouTube. Automatic timestamp detection, proper playback controls including shuffle, and more.",
  "permissions": [
    "storage"
  ],
  "options_page": "options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "timestamp-player-for-youtube@cloudspiral",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "16": "icons/timestamp-player-youtube-16.png",
    "32": "icons/timestamp-player-youtube-32.png",
    "48": "icons/timestamp-player-youtube-48.png",
    "128": "icons/timestamp-player-youtube-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*",
        "https://music.youtube.com/watch*"
      ],
      "js": [
        "src/settings.js",
        "src/timestamps.js",
        "src/native-timestamps.js",
        "src/comment-scoring.js",
        "src/comment-fetching.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
